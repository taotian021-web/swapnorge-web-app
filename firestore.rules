/**
 * @file Firestore Security Rules for NeighborBuy
 * @version Prototyping Mode - Data shape is not strictly enforced. Authorization is strictly enforced.
 *
 * @Core Philosophy:
 *   This ruleset enforces a user-ownership model for most data, with a public read for marketplace listings.
 *
 * @Data Structure:
 *   - /users/{userId}: User profiles, accessible only by the user themselves.
 *   - /users/{userId}/products/{productId}: Products owned by a specific user, accessible only by that user.
 *   - /products/{productId}: Public marketplace listings, readable by anyone, but writable only by the owner.  Contains denormalized userId for simpler rules.
 *   - /products/{productId}/verifications/{verificationId}:  Verifications of products, only creatable by the user.
 *   - /users/{userId}/ratings/{ratingId}: Ratings created by a user.
 *
 * @Key Security Decisions:
 *   - User listing is disallowed.
 *   - Public read access is granted only to the /products collection.
 *
 * @Denormalization for Authorization:
 *   - The /products/{productId} document contains a denormalized 'userId' field, copied from the user's profile.
 *     This allows rules on /products to validate ownership without needing to perform expensive 'get()' operations on the /users collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to user profiles.
     * @path /users/{userId}
     * @allow (get, list, update, delete) if the user is the owner. (create) if the user's ID matches the document ID.
     *   Example: User with ID 'user123' can read, update, and delete /users/user123.
     * @deny (create) if the user's ID does not match the document ID.
     *   Example: User with ID 'user456' cannot create /users/user123.
     * @principle Enforces document ownership and validates relational integrity.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if request.auth.uid == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows access to products created by a specific user.
     * @path /users/{userId}/products/{productId}
     * @allow (get, list, update, delete) if the user is the owner. (create) if the user is the owner.
     *   Example: User with ID 'user123' can read, update, and delete /users/user123/products/product456.
     * @deny Any operation by a different user.
     *   Example: User with ID 'user456' cannot create, read, update, or delete /users/user123/products/product456.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/products/{productId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows public read access to products, but restricts write access to the owner.
     * @path /products/{productId}
     * @allow (get, list) to anyone. (create) if the user's ID matches the userId in the document. (update, delete) if the user is the owner of the product.
     *   Example: Any user can read /products/product123.
     *   Example: User with ID 'user123' can create /products/product456 where product456.userId == 'user123'.
     * @deny (create) if the user's ID does not match the userId in the document. (update, delete) if the user is not the owner of the product.
     *   Example: User with ID 'user456' cannot create /products/product123 where product123.userId != 'user456'.
     * @principle Allows public read access with owner-only writes.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    /**
     * @description Allows users to create verifications for a product.
     * @path /products/{productId}/verifications/{verificationId}
     * @allow (get, list, create, update, delete) if the user is signed in.
     *   Example: User 'user123' can create /products/product456/verifications/verification789.
     * @deny Any operation by an unauthenticated user.
     *   Example: An unauthenticated user cannot create, read, update, or delete /products/product456/verifications/verification789.
     * @principle Enforces that only signed-in users can create verifications.
     */
    match /products/{productId}/verifications/{verificationId} {
      allow get: if request.auth != null;
      allow list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /**
     * @description Allows users to create ratings.
     * @path /users/{userId}/ratings/{ratingId}
     * @allow (get, list, create, update, delete) if the user is the owner.
     *   Example: User 'user123' can create /users/user123/ratings/rating456.
     * @deny Any operation by a different user.
     *   Example: User 'user456' cannot create, read, update, or delete /users/user123/ratings/rating456.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/ratings/{ratingId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}