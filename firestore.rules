/**
 * @file Firestore Security Rules for SwapNorge
 * @version 2.0 - 生产级安全规则
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** 
     * @section 用户配置
     * 只有本人可以读写自己的 Profile。
     */
    match /users/{userId} {
      allow get: if request.auth != null;
      allow create, update, delete: if request.auth.uid == userId;

      // 用户收藏夹子集合
      match /favorites/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    /** 
     * @section 物品集合
     * 任何人可读公共物品。只有卖家可以增删改自己的物品。
     */
    match /items/{itemId} {
      function isSeller() {
        return request.auth.uid == resource.data.sellerId;
      }
      function isCreatingOwn() {
        return request.auth.uid == request.resource.data.sellerId;
      }

      allow read: if true;
      allow create: if request.auth != null && isCreatingOwn();
      allow update, delete: if request.auth != null && isSeller();
    }

    /** 
     * @section 交换请求
     * 只有发起者 (sender) 或 接收者 (receiver) 可以读取请求。
     * 只有参与者可以更新状态。
     */
    match /swapRequests/{requestId} {
      function isParticipant() {
        return request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId;
      }

      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId;
      allow read, update, delete: if request.auth != null && isParticipant();
    }

    /** 
     * @section 评价系统
     * 所有人可读评价。只有登录用户可以创建评价。
     */
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromId;
    }
  }
}