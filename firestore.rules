/**
 * @file Firestore Security Rules for NeighborBuy
 * @version Prototyping Mode - Data shape is not strictly enforced. Authorization is strictly enforced.
 *
 * @Core Philosophy:
 *   This ruleset enforces a user-ownership model for most data, with a public read for marketplace listings.
 *
 * @Data Structure:
 *   - /users/{userId}: User profiles, accessible only by the user themselves.
 *   - /users/{userId}/products/{productId}: Private product drafts owned by a user, accessible only by that user.
 *   - /products/{productId}: Public marketplace listings, readable by anyone, but writable only by the owner.
 *   - /products/{productId}/verifications/{verificationId}:  Verifications of products, only creatable by a signed-in user.
 *   - /users/{userId}/ratings/{ratingId}: Ratings created by a user.
 *
 * @Key Security Decisions:
 *   - User listing is disallowed.
 *   - Public read access is granted only to the /products collection.
 *   - A user's own products subcollection is private to them.
 *
 * @Denormalization for Authorization:
 *   - The /products/{productId} document contains a denormalized 'userId' field, copied from the user's profile.
 *     This allows rules on /products to validate ownership without needing to perform expensive 'get()' operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to user profiles.
     * @path /users/{userId}
     * @allow (get, update, delete) if the user is the owner. (create) if the user's ID matches the document ID.
     * @deny (list) to prevent user enumeration.
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow get: if isOwner();
      allow list: if false; // Disallow listing all users
      allow create: if request.auth.uid == userId;
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    /**
     * @description Allows a user to manage their own private products (drafts).
     * @path /users/{userId}/products/{productId}
     * @allow (get, list, create, update, delete) if the user is the owner of this subcollection.
     * @principle Enforces strict data ownership for user-specific content before it's made public.
     */
    match /users/{userId}/products/{productId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read, write: if isOwner();
    }

    /**
     * @description Allows public read access to shared products, but restricts write access to the owner.
     * @path /products/{productId}
     * @allow (get, list) to anyone for public listings.
     * @allow (create, update, delete) if the user's ID matches the `userId` in the document data.
     * @principle Enables a public marketplace while maintaining owner-only write control on public data.
     */
    match /products/{productId} {
      function isProductOwner() {
        // userId is a legacy name for sellerId, it's what's in the data.
        return request.auth.uid == resource.data.sellerId;
      }
      
      function isCreatingOwnProduct() {
        // userId is a legacy name for sellerId, it's what's in the data.
        return request.auth.uid == request.resource.data.sellerId;
      }

      allow read: if true;
      allow create: if isCreatingOwnProduct();
      allow update: if isProductOwner();
      allow delete: if isProductOwner();
    }

    /**
     * @description Allows any authenticated user to create verifications for a product.
     * @path /products/{productId}/verifications/{verificationId}
     * @allow (read, write) if the user is signed in.
     * @principle Encourages community participation by authenticated users.
     */
    match /products/{productId}/verifications/{verificationId} {
      allow read, write: if request.auth != null;
    }

    /**
     * @description Allows users to create and manage their own ratings.
     * @path /users/{userId}/ratings/{ratingId}
     * @allow (read, write) if the user is the owner.
     * @principle Enforces document ownership for user-generated feedback.
     */
    match /users/{userId}/ratings/{ratingId} {
      function isOwner() {
        return request.auth.uid == userId;
      }

      allow read, write: if isOwner();
    }
  }
}
