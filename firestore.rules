
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 用户资料：所有人可读（查看信誉），仅本人可写
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      // 收藏夹子集合
      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 物品集合：所有人可读，仅发布者可写
    match /items/{itemId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
      
      // 允许非作者更新浏览量和点赞数
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes']);
    }

    // 交换请求：发送者和接收者可见
    match /swapRequests/{requestId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
    }

    // 评价：所有人可读，买家可写
    match /reviews/{reviewId} {
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
    }

    // 基础参考数据
    match /locations/{locationId} { allow read: if isSignedIn(); }
    match /categories/{categoryId} { allow read: if isSignedIn(); }
  }
}
