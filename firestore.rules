
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 通用函数 ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 用户资料 ---
    match /users/{userId} {
      // 允许所有登录邻居查看（用于信誉查询），仅本人可修改
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- 物品集合 (Items) ---
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      // 允许本人更新，或仅允许他人更新浏览量/点赞数
      allow update: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes'])
      );
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // --- 交换请求 (Swap Requests) ---
    match /swapRequests/{requestId} {
      // 允许参与双方进行列表查询
      allow get, list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
    }

    // --- 评价 (Reviews) ---
    match /reviews/{reviewId} {
      // 允许所有登录邻居查看列表
      allow read, get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
    }

    // --- 基础参考数据 ---
    match /locations/{locationId} { allow read: if isSignedIn(); }
    match /categories/{categoryId} { allow read: if isSignedIn(); }
  }
}
