
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 用户档案：公开可查（显示评价和声誉），仅限本人修改
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 物品清单：公开浏览（无需登录），创建和修改需本人
    match /items/{itemId} {
      allow read, get, list: if true; 
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'status'])
      );
      allow delete: if isSignedIn() && resource.data.sellerId == request.auth.uid;
    }

    // 交换请求：仅限发送方和接收方查看
    match /swapRequests/{requestId} {
      allow read, get, list: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
    }

    // 评价：公开可读，仅限发送方创建
    match /reviews/{reviewId} {
      allow read, get, list: if true;
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
    }

    // 基础参考数据：公开可读
    match /locations/{locationId} { allow read: if true; }
    match /categories/{categoryId} { allow read: if true; }
  }
}
