
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Extended user profile with points and reputation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "points": { "type": "number" },
            "reputation": { "type": "number" },
            "completedSwaps": { "type": "number" },
            "memberSince": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "SwapItem": {
      "title": "SwapItem",
      "description": "Represents an item listed for swapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "category": { "type": "string" },
        "condition": { "type": "string", "enum": ["new", "likeNew", "good", "fair"] },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerRating": { "type": "number" },
        "postedDate": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" },
        "status": { "type": "string", "enum": ["available", "reserved", "swapped"] },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "city": { "type": "string" }
          }
        }
      }
    },
    "SwapRequest": {
      "title": "SwapRequest",
      "description": "A request to swap an item.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "itemTitle": { "type": "string" },
        "itemImageUrl": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "receiverName": { "type": "string" },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A saved item bookmark.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Neighbor vouch note.",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "requestId": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/favorites/{itemId}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "User's bookmarked items."
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/SwapItem" },
      "description": "Marketplace items."
    },
    "/swapRequests/{requestId}": {
      "schema": { "$ref": "#/entities/SwapRequest" },
      "description": "Trade requests."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Neighbor reviews."
    }
  }
}
