{
  "entities": {
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a single information post on NabeFeed.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the post." },
        "userId": { "type": "string", "description": "Reference to the User who created the post." },
        "name": { "type": "string", "description": "The title or main content of the post." },
        "description": { "type": "string", "description": "Optional supplementary details." },
        "category": { "type": "string", "enum": ["FreshNews", "Help", "ForSale", "Activity"], "description": "The category of the post." },
        "locationName": { "type": "string", "description": "Name of the location, e.g., 'Community East Gate'." },
        "postedDate": { "type": "string", "format": "date-time", "description": "Timestamp of post creation." },
        "price": { "type": "number", "description": "Price for 'ForSale' items." },
        "validUntil": { "type": "string", "description": "Expiration time for 'FreshNews'." },
        "urgency": { "type": "string", "enum": ["normal", "urgent"], "description": "Urgency level for 'Help' requests." },
        "likes": { "type": "number", "description": "Count of 'Useful' clicks." },
        "views": { "type": "number", "description": "Count of views." },
        "isPublic": { "type": "boolean", "description": "Controls visibility in the public feed." }
      },
      "required": ["id", "userId", "name", "category", "postedDate"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Post",
          "schema": { "$ref": "#/entities/Post" },
          "description": "Stores all public posts for the NabeFeed timeline. Renamed from 'products' for legacy reasons but holds 'Post' entities."
        }
      },
       {
        "path": "/users/{userId}/products/{productId}",
        "definition": {
          "entityName": "Post",
          "schema": {
            "$ref": "#/entities/Post"
          },
          "description": "Stores a user's own posts for management. Renamed from 'products' for legacy reasons."
        }
      }
    ]
  }
}
