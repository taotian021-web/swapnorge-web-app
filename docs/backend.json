
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Extended user profile with points and reputation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "points": { "type": "number" },
            "reputation": { "type": "number" },
            "completedSwaps": { "type": "number" },
            "memberSince": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "SwapItem": {
      "title": "SwapItem",
      "description": "Represents an item listed for swapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerRating": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "reserved", "swapped"] }
      }
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A saved item bookmark.",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/users/{userId}/favorites/{itemId}": {
      "schema": { "$ref": "#/entities/Favorite" },
      "description": "User's bookmarked items."
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/SwapItem" },
      "description": "Marketplace items."
    },
    "/swapRequests/{requestId}": {
      "schema": { "$ref": "#/entities/SwapRequest" },
      "description": "Trade requests."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Neighbor reviews."
    }
  }
}
