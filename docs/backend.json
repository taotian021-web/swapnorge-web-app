
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Extended user profile with points and reputation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "points": { "type": "number", "description": "Virtual currency balance." },
            "reputation": { "type": "number", "description": "Average rating out of 5." },
            "completedSwaps": { "type": "number" },
            "memberSince": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "SwapItem": {
      "title": "SwapItem",
      "description": "Represents an item listed for swapping.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "category": { "type": "string", "enum": ["Elektronikk", "Klær", "Hjem", "Bøker", "Sport", "Annet"] },
        "imageUrl": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerRating": { "type": "number" },
        "postedDate": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "city": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["available", "reserved", "swapped"] }
      },
      "required": ["title", "points", "sellerId", "category"]
    },
    "SwapRequest": {
      "title": "SwapRequest",
      "description": "A transaction request from one user to another for an item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "itemId": { "type": "string" },
        "itemTitle": { "type": "string" },
        "points": { "type": "number" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "completed", "disputed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and stats."
    },
    "/items/{itemId}": {
      "schema": { "$ref": "#/entities/SwapItem" },
      "description": "Global public items list."
    },
    "/swapRequests/{requestId}": {
      "schema": { "$ref": "#/entities/SwapRequest" },
      "description": "Transaction logs and active requests."
    }
  }
}
